<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/home_fragment_frameLayout"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:background="@drawable/fragment_background"
    android:layout_centerInParent="true"
    tools:context=".HomeFragment">

    <Toolbar
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/purple_200"
        android:id="@+id/toolbar"
        android:title="CATEGORIES"
        android:paddingLeft="15dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">


        <GridLayout
            android:id="@+id/grid_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="fill"
            android:layout_marginTop="15dp"
            android:layout_marginStart="15dp"
            android:columnCount="2"
            android:rowCount="2"
            tools:ignore="MissingConstraints">

            <TextView
                android:id="@+id/homefrag_vegetables"
                android:layout_width="180dp"
                android:layout_height="90dp"
                android:layout_margin="7dp"
                android:background="@drawable/home_frag_item_background"
                android:paddingTop="25dp"
                android:text="VEGETABLES"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="25sp" />

            <TextView
                android:id="@+id/homefrag_fruit"
                android:layout_width="180dp"
                android:layout_height="90dp"
                android:layout_margin="7dp"
                android:background="@drawable/home_frag_item_background"
                android:paddingTop="25dp"
                android:text="FRUİT"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="25sp" />

            <TextView
                android:id="@+id/homefrag_medicine"
                android:layout_width="180dp"
                android:layout_height="90dp"
                android:layout_margin="7dp"
                android:background="@drawable/home_frag_item_background"
                android:paddingTop="25dp"
                android:text="MEDICINE"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="25sp" />

            <TextView
                android:id="@+id/homefrag_beverage"
                android:layout_width="180dp"
                android:layout_height="90dp"
                android:layout_margin="7dp"
                android:background="@drawable/home_frag_item_background"
                android:paddingTop="25dp"
                android:text="BEVERAGE"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="25sp" />

            <TextView
                android:id="@+id/homefrag_dessert"
                android:layout_width="180dp"
                android:layout_height="90dp"
                android:layout_margin="7dp"
                android:background="@drawable/home_frag_item_background"
                android:paddingTop="25dp"
                android:text="DESSERT"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="25sp" />

            <TextView
                android:id="@+id/homefrag_others"
                android:layout_width="180dp"
                android:layout_height="90dp"
                android:layout_margin="7dp"
                android:background="@drawable/home_frag_item_background"
                android:paddingTop="25dp"
                android:text="OTHERS"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="25sp" />


        </GridLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

